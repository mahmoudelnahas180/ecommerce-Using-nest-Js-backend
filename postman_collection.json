{
  "info": {
    "name": "Ecommerce API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Sign Up",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"securePassword123\",\n  \"role\": \"user\",\n  \"age\": 25,\n  \"avatar\": \"https://example.com/avatar.jpg\",\n  \"phoneNumber\": \"01012345678\",\n  \"address\": \"123 Main St, Cairo\",\n  \"active\": true,\n  \"vervactionCode\": \"1234\",\n  \"gender\": \"male\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/signup",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "signup"]
            }
          }
        },
        {
          "name": "Sign In",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"securePassword123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/signin",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "signin"]
            }
          }
        }
      ]
    },
    {
      "name": "Category",
      "item": [
        {
          "name": "Create Category",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Electronics\",\n  \"image\": \"https://example.com/electronics.jpg\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/category/create",
              "host": ["{{baseUrl}}"],
              "path": ["category", "create"]
            }
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get Users (Auth Required)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/users/",
              "host": ["{{baseUrl}}"],
              "path": ["users", ""]
            }
          }
        },
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/users/allusers",
              "host": ["{{baseUrl}}"],
              "path": ["users", "allusers"]
            }
          }
        },
        {
          "name": "Create User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jane Doe\",\n  \"email\": \"jane@example.com\",\n  \"password\": \"securePassword123\",\n  \"role\": \"user\",\n  \"age\": 30,\n  \"avatar\": \"https://example.com/avatar.jpg\",\n  \"phoneNumber\": \"01112345678\",\n  \"address\": \"456 Elm St, Alex\",\n  \"active\": true,\n  \"vervactionCode\": \"5678\",\n  \"gender\": \"female\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/users/createuser",
              "host": ["{{baseUrl}}"],
              "path": ["users", "createuser"]
            }
          }
        },
        {
          "name": "Get User by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/users/64abc12345def67890123456",
              "host": ["{{baseUrl}}"],
              "path": ["users", "64abc12345def67890123456"]
            }
          }
        },
        {
          "name": "Update User by ID",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"age\": 31,\n  \"address\": \"789 New St\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/users/64abc12345def67890123456",
              "host": ["{{baseUrl}}"],
              "path": ["users", "64abc12345def67890123456"]
            }
          }
        },
        {
          "name": "Delete User by ID",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/users/64abc12345def67890123456",
              "host": ["{{baseUrl}}"],
              "path": ["users", "64abc12345def67890123456"]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "token",
      "value": "your_jwt_token_here_if_auth_is_needed",
      "type": "string"
    }
  ]
}
